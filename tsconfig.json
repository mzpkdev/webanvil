{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "verbatimModuleSyntax": true
  },
  "include": ["arguments/**/*.ts", "cli.ts", "commands/**/*.ts", "core/**/*.ts", "vite.config.ts"]
}
