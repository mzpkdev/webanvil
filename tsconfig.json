{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "verbatimModuleSyntax": true
  },
  "include": [
    "arguments/**/*.ts",
    "build.config.ts",
    "commands/**/*.ts",
    "core/**/*.ts"
  ]
}
