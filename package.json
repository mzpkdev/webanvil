{
    "name": "webanvil",
    "version": "1.0.0",
    "bin": {
        "wa": "bin/webanvil",
        "webanvil": "bin/webanvil"
    },
    "type": "module",
    "main": "./dist/index.mjs",
    "scripts": {
        "build": "obuild",
        "pretest": "npm run build",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "typecheck": "npm run build && node bin/webanvil typecheck",
        "lint": "npm run build && node bin/webanvil lint",
        "lint:fix": "npm run build && node bin/webanvil lint --fix",
        "format": "npm run build && node bin/webanvil format",
        "format:check": "npm run build && node bin/webanvil format --check",
        "check": "npm run typecheck && npm run lint && npm run format:check && npm test"
    },
    "dependencies": {
        "@typescript/native-preview": "^7.0.0-dev.20260707.2",
        "c12": "^4.0.0-beta.5",
        "cmdore": "^0.4.1",
        "consola": "^3.4.2",
        "defu": "^6.1.7",
        "jsdom": "^29.1.1",
        "mlly": "^1.8.2",
        "pathe": "^2.0.3",
        "pkg-types": "^2.3.1",
        "rolldown": "^1.2.0",
        "tinyglobby": "^0.2.15",
        "unplugin": "^3.3.0",
        "vite": "^8.1.5",
        "vitest": "^4.1.10",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "obuild": "^0.4.38",
        "oxfmt": "^0.60.0",
        "oxlint": "^1.75.0"
    }
}
