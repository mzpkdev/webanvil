{
    "name": "@crazy-pocs/webanvil",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "bin": {
        "webanvil": "./src/cli.ts"
    },
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./src/index.ts"
        }
    },
    "files": [
        "dist",
        "webanvil.schema.json"
    ],
    "publishConfig": {
        "bin": {
            "webanvil": "./dist/cli.mjs"
        },
        "main": "./dist/index.mjs",
        "types": "./dist/index.d.mts",
        "exports": {
            ".": {
                "types": "./dist/index.d.mts",
                "import": "./dist/index.mjs"
            }
        }
    },
    "scripts": {
        "build": "unbuild",
        "dev": "tsx watch src/cli.ts",
        "typecheck": "node node_modules/typescript-native/bin/tsc --noEmit",
        "test": "vitest run",
        "schema": "bun run src/schema.ts"
    },
    "dependencies": {
        "@biomejs/biome": "^2.3.0",
        "@types/node": "^24.13.3",
        "c12": "4.0.0-beta.5",
        "cmdore": "^0.4.1",
        "defu": "^6.1.7",
        "giget": "^3.3.0",
        "jiti": "^2.7.0",
        "turbo": "^2.10.4",
        "tsx": "^4.19.0",
        "typescript": "^5.9.3",
        "typescript-native": "npm:typescript@^7.0.0",
        "unbuild": "^3.6.0",
        "vite": "^8.1.3",
        "vitest": "^4.1.10",
        "zod": "^4.4.3"
    }
}
